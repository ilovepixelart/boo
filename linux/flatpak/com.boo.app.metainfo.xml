<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>com.boo.app</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>MIT</project_license>

  <name>Boo</name>
  <summary>Local speech-to-text overlay</summary>

  <developer id="io.github.ilovepixelart">
    <name>ilovepixelart</name>
  </developer>

  <url type="homepage">https://github.com/ilovepixelart/boo</url>
  <url type="bugtracker">https://github.com/ilovepixelart/boo/issues</url>
  <url type="vcs-browser">https://github.com/ilovepixelart/boo</url>

  <!-- Transcribes the user's own speech locally; no content of any kind is
       generated, exchanged, or transmitted. -->
  <content_rating type="oars-1.1"/>

  <description>
    <p>
      Boo is a local speech-to-text overlay that captures audio from your
      microphone and transcribes it on-device using whisper.cpp. Press
      Ctrl+Shift+Space (after approving the shortcut on first launch) or
      click the Record button, speak, and the transcript is copied to the
      clipboard and pasted into the focused app.
    </p>
    <p>
      Everything runs locally — no audio leaves your machine.
    </p>
  </description>

  <launchable type="desktop-id">com.boo.app.desktop</launchable>

  <categories>
    <category>Office</category>
    <category>AudioVideo</category>
    <category>Utility</category>
  </categories>

  <supports>
    <control>pointing</control>
    <control>keyboard</control>
    <control>touch</control>
  </supports>

  <requires>
    <display_length compare="ge">360</display_length>
  </requires>

  <releases>
    <release version="0.1.0" date="2026-05-06">
      <description>
        <p>Initial Linux preview build.</p>
      </description>
    </release>
  </releases>
</component>
