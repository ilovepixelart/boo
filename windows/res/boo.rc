// Icon and version resources. Compiled by Zig's built-in resource compiler
// (resinator), so this works when cross-compiling too. The version numbers
// are checked against build.zig.zon by scripts/check-version.sh.

#include "../src/resource.h"

IDI_BOO ICON "boo.ico"

1 VERSIONINFO
FILEVERSION 0,4,2,0
PRODUCTVERSION 0,4,0,0
BEGIN
  BLOCK "StringFileInfo"
  BEGIN
    BLOCK "040904B0"
    BEGIN
      VALUE "FileDescription", "Boo speech-to-text overlay"
      VALUE "FileVersion", "0.4.2"
      VALUE "ProductName", "Boo"
      VALUE "ProductVersion", "0.4.2"
      VALUE "OriginalFilename", "boo-app.exe"
      VALUE "LegalCopyright", "MIT License"
    END
  END
  BLOCK "VarFileInfo"
  BEGIN
    VALUE "Translation", 0x409, 1200
  END
END
