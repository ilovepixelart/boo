# Consistency across every language in the tree. Editors that honor
# EditorConfig apply these without a per-project setup step.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{yml,yaml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false  # two trailing spaces is a hard line break

[Makefile]
indent_style = tab
